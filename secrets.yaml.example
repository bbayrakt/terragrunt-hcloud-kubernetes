# Example secrets file
# This file should be encrypted with SOPS before committing
# 
# To encrypt this file:
#   sops -e -i secrets.yaml
# 
# To edit the encrypted file:
#   sops secrets.yaml
# 
# To decrypt for viewing:
#   sops -d secrets.yaml

# Hetzner Cloud API Token
hcloud_token: "YOUR_HCLOUD_TOKEN_HERE"

# MinIO / S3-Compatible Backend Configuration
minio_endpoint: "http://YOUR_MINIO_ENDPOINT"
minio_access_key: "YOUR_MINIO_USER_NAME"
minio_secret_key: "YOUR_MINIO_PASSWORD"

# Add additional secrets as needed
# example_secret: "value"
# database_password: "secure_password"
