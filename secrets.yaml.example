# Example secrets file
# This file should be encrypted with SOPS before committing
# 
# To encrypt this file:
#   sops -e -i secrets.yaml
# 
# To edit the encrypted file:
#   sops secrets.yaml
# 
# To decrypt for viewing:
#   sops -d secrets.yaml

# Hetzner Cloud API Token
hcloud_token: "YOUR_HCLOUD_TOKEN_HERE"

# SeaweedFS / S3-Compatible Backend Configuration
seaweedfs_endpoint: "http://YOUR_SEAWEEDFS_ENDPOINT"
seaweedfs_access_key: "YOUR_SEAWEEDFS_ACCESS_KEY"
seaweedfs_secret_key: "YOUR_SEAWEEDFS_SECRET_KEY"

# Let's Encrypt / Cert Manager Configuration
acme_email: "admin@example.com"

# Gateway API Configuration
gateway_api_lb_name: "k8s-gateway"
gateway_api_domain: "example.com"

# External DNS / Cloudflare Configuration
# External DNS automatically creates DNS A records from Gateway API resources
cloudflare_api_token: "YOUR_CLOUDFLARE_API_TOKEN"

# Add additional secrets as needed
# example_secret: "value"
# database_password: "secure_password"
